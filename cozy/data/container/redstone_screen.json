{
  "namespace": "cozy_screen:redstone",
  
  "1x5_screen_content@screen_content": {
    "$size": [176.0, 133.0]
  },
  
  "3x3_screen_content@screen_content": {
    "$size": [176.0, 166.0]
  },
  
  "screen_content": {
    "type": "panel",
    "size": ["100.0%", "100.0%"],
    "layer": 10,
    "controls": [
      {
        "screen_panel@cozy_common:container.screen_base": {
          "$size": "$size",
          "controls": [
            {
              "container_exit_button@cozy_common:container.container_exit_button": {}
            },
            {
              "1x5_gird_panel@cozy_screen:redstone.1x5_grid_panel": {
                "ignored": "(not ($container = hopper))",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [0.0, "114514.1919810%cm + 2.0px"]
              }
            },
            {
              "3x3_gird_panel@cozy_screen:redstone.3x3_grid_panel": {
                "ignored": "(not (($container = dropper) or ($container = dispenser)))",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [0.0, "114514.1919810%cm"]
              }
            },
            {
              "crafter_gird_panel@cozy_screen:redstone.crafter_grid_panel": {
                "ignored": "(not ($container = crafter))",
                "$button_ref|default": "redstone.crafter_container_slot_button_prototype",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": ["-20.75%", "-8.25%x"]
              }
            },
            {
              "crafter_top_half_panel": {
                "type": "panel",
                "size": ["100.0%", "50.0%"],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "layer": 20,
                "controls": [
                  {
                    "redstone_wire_line": {
                      "type": "image",
                      "size": ["10.22727272727%", "21.68674698795%"],
                      "offset": ["9.7%", "2.0%"],
                      "layer": 5,
                      "bindings": [
                        {
                          "binding_name": "#redstone_arrow_texture",
                          "binding_name_override": "#texture"
                        }
                      ]
                    }
                  },
                  {
                    "output_slot_hover_info@cozy_screen:redstone.output_slot_hover_info": {}
                  }
                ]
              }
            },
            {
              "hotbar_inventory_content@cozy_common:container.hotbar_inventory_content": {}
            },
            {
              "container_utils_content@cozy_common:container.container_utils_content": {}
            }
          ]
        }
      },
      {
        "container_gamepad_helpers@common.container_gamepad_helpers": {}
      },
      {
        "selected_item_details_factory@common.selected_item_details_factory": {}
      },
      {
        "item_lock_notification_factory@common.item_lock_notification_factory": {}
      }
    ]
  },
  
  "output_slot_hover_info": {
    "type": "button",
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "hover_control": "hover",
    "size": ["14.77272727272%", "31.32530120481%"],
    "offset": ["30.5%", "2.1346%"],
    "$stack_count_required": true,
    "controls": [
      {
        "hover@common.hover_text": {
          "layer": 29,
          "bindings": [
            {
              "binding_name": "#crafting_preview_info",
              "binding_name_override": "#hover_text"
            }
          ]
        }
      },
      {
        "output_slot@common.item_renderer": {
          "size": ["83.33333333333%", "88.23529411764%"],
          "bindings": [
            {
              "binding_name": "#crafter_output_item",
              "binding_name_override": "#item_id_aux"
            },
            {
              "binding_name": "#crafter_output_item_color",
              "binding_name_override": "#item_custom_color"
            },
            {
              "binding_name": "#crafter_output_item_shield_base_color_hovered",
              "binding_name_override": "#shield_base_color"
            },
            {
              "binding_name": "#crafter_output_item_banner_patterns",
              "binding_name_override": "#banner_patterns"
            },
            {
              "binding_name": "#crafter_output_item_selected_banner_colors",
              "binding_name_override": "#banner_colors"
            },
            {
              "binding_name": "#crafter_output_item_selected_banner_type",
              "binding_name_override": "#banner_type"
            },
            {
              "binding_name": "#crafter_output_item_selected_decorated_pot_sherds",
              "binding_name_override": "#decorated_pot_sherds"
            }
          ]
        }
      },
      {
        "output_count@common.stack_count_label": {
          "layer": 30,
          "font_type": "$cozy_global_font_type",
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "bindings": [
            {
              "binding_name": "#output_stack_count",
              "binding_name_override": "#inventory_stack_count"
            }
          ]
        }
      }
    ]
  },
  
  "1x5_grid_panel": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": ["100.0%c", "100.0%cm"],
    "$item_collection_name": "container_items",
    "collection_name": "$item_collection_name",
    "controls": [
      {
        "0@cozy_common:container.container_item": {
          "collection_index": 0
        }
      },
      {
        "1@cozy_common:container.container_item": {
          "collection_index": 1
        }
      },
      {
        "2@cozy_common:container.container_item": {
          "collection_index": 2
        }
      },
      {
        "3@cozy_common:container.container_item": {
          "collection_index": 3
        }
      },
      {
        "4@cozy_common:container.container_item": {
          "collection_index": 4
        }
      }
    ]
  },
  
  "3x3_grid_panel": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100.0%cm", "100.0%c"],
    "$item_collection_name": "container_items",
    "controls": [
      {
        "horizontal0": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100.0%c", "100.0%cm"],
          "collection_name": "$item_collection_name",
          "controls": [
            {
              "0@cozy_common:container.container_item": {
                "collection_index": 0
              }
            },
            {
              "1@cozy_common:container.container_item": {
                "collection_index": 1
              }
            },
            {
              "2@cozy_common:container.container_item": {
                "collection_index": 2
              }
            }
          ]
        }
      },
      {
        "horizontal1": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100.0%c", "100.0%cm"],
          "collection_name": "$item_collection_name",
          "controls": [
            {
              "0@cozy_common:container.container_item": {
                "collection_index": 3
              }
            },
            {
              "1@cozy_common:container.container_item": {
                "collection_index": 4
              }
            },
            {
              "2@cozy_common:container.container_item": {
                "collection_index": 5
              }
            }
          ]
        }
      },
      {
        "horizontal2": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100.0%c", "100.0%cm"],
          "collection_name": "$item_collection_name",
          "controls": [
            {
              "0@cozy_common:container.container_item": {
                "collection_index": 6
              }
            },
            {
              "1@cozy_common:container.container_item": {
                "collection_index": 7
              }
            },
            {
              "2@cozy_common:container.container_item": {
                "collection_index": 8
              }
            }
          ]
        }
      }
    ]
  },
  
  "crafter_grid_panel": {
    "type": "panel",
    "size": ["100.0%c", "100.0%c"],
    "controls": [
      {
        "3x3_grid_panel@cozy_screen:redstone.3x3_grid_panel": {}
      },
      {
        "crafter_disabled_button_panel@cozy_screen:redstone.crafter_disabled_button_panel": {}
      }
    ]
  },
  
  "crafter_disabled_button_panel": {
    "type": "panel",
    "layer": 21,
    "size": "$size",
    "$size": [54.0, 54.0],
    "anims": [
      "@cozy_animations:container.container_animation_size_exit_push",
      "@cozy_animations:container.container_animation_size_exit_pop",
      "@cozy_animations:container.container_animation_size_enter_pop",
      "@cozy_animations:container.container_animation_size_enter_push"
    ],
    "animation_reset_name": "screen_animation_reset",
    "controls": [
      {
        "top_left@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "top_left",
          "$index": 0
        }
      },
      {
        "top_middle@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "top_middle",
          "$index": 1
        }
      },
      {
        "top_right@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "top_right",
          "$index": 2
        }
      },
      {
        "left_middle@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "left_middle",
          "$index": 3
        }
      },
      {
        "center@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "center",
          "$index": 4
        }
      },
      {
        "right_middle@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "right_middle",
          "$index": 5
        }
      },
      {
        "bottom_left@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "bottom_left",
          "$index": 6
        }
      },
      {
        "bottom_middle@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "bottom_middle",
          "$index": 7
        }
      },
      {
        "bottom_right@cozy_screen:redstone.crafter_disabled_slot_template": {
          "$anchor": "bottom_right",
          "$index": 8
        }
      }
    ]
  },
  
  "crafter_disabled_slot_template@common.button": {
    "type": "button",
    "anchor_from": "$anchor",
    "anchor_to": "$anchor",
    "hover_control": "hover",
    "size": "$size",
    "$size": [18.0, 18.0],
    "anims": [
      "@cozy_animations:container.container_animation_size_exit_push",
      "@cozy_animations:container.container_animation_size_exit_pop",
      "@cozy_animations:container.container_animation_size_enter_pop",
      "@cozy_animations:container.container_animation_size_enter_push"
    ],
    "animation_reset_name": "screen_animation_reset",
    "layer": 21,
    "$pressed_button_name": "('disabled_button' + $index)",
    "bindings": [
      {
        "binding_name": "('#button_visible' + $index)",
        "binding_name_override": "#visible"
      }
    ],
    "controls": [
      {
        "default": {
          "type": "image",
          "texture": "cozy/sprites/redstone/disabled_slot"
        }
      },
      {
        "hover": {
          "type": "image",
          "texture": "cozy/sprites/redstone/disabled_slot"
        }
      },
      {
        "pressed": {
          "type": "image",
          "texture": "cozy/sprites/redstone/disabled_slot"
        }
      }
    ]
  }
}