  "inventory_grid_item": {
    "type": "panel",
    "collection_index": "$index",
    "size": ["17.0px", "17.0px"],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "hotbar_items"
      }
    ],
    "controls": [
      {
        "main": {
          "type": "panel",
          "size": ["100.0%", "100.0%"],
          "$stack_count_required|default": true,
          "$item_collection_name": "hotbar_items",
          "controls": [
            {
              "item_renderer@common.item_renderer": {
                "layer": 10,
                "$item_renderer_size|default": [13.0, 13.0],
                "size": [13.0, 13.0]
              }
            },
            {
              "item_stack_count@common.stack_count_label": {
                "layer": 20,
                "offset": [-0.78, -0.78],
                "anchor_from": "bottom_right",
                "anchor_to": "bottom_right",
                "font_type": "$cozy_feature_inventory_display_stack_count_font_type",
                "shadow": true,
                "font_scale_factor": 1.0,
                "bindings": [
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "hotbar_items",
                    "binding_name": "#inventory_stack_count"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  
