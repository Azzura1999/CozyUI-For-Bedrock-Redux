    "$checked_hover_control": "cozy_screen:trade.trade_toggle_checked",
    "$unchecked_locked_control": "cozy_screen:trade.trade_toggle_locked",
    "$unchecked_locked_hover_control": "cozy_screen:trade.trade_toggle_locked",
    "$checked_locked_control": "cozy_screen:trade.trade_toggle_locked",
    "$checked_locked_hover_control": "cozy_screen:trade.trade_toggle_locked"
  },
  
  "toggle_content_holder": {
    "type": "panel",
    "layer": 10,
    "size": [
      "100%",
