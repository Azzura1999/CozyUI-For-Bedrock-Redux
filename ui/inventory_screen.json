{
  "inventory_screen@crafting.inventory_screen_base": {
    "$screen_content": "crafting.inventory_screen_content",
    "$screen_bg_content": "common.empty_panel",
    "close_on_player_hurt": "$cozy_container_screen_close_on_player_hurt",
    "$screen_animations": [
      "@cozy_animations:container.container_animation_alpha_exit_push",
      "@cozy_animations:container.container_animation_alpha_exit_pop",
      "@cozy_animations:container.container_animation_alpha_enter_pop",
      "@cozy_animations:container.container_animation_alpha_enter_push"
    ]
  },
  "crafting_screen@crafting.inventory_screen_base": {
    "$screen_content": "cozy_screen:inventory.crafting_screen_content",
    "$screen_bg_content": "common.empty_panel",
    "close_on_player_hurt": "$cozy_container_screen_close_on_player_hurt",
    "$screen_animations": [
      "@cozy_animations:container.container_animation_alpha_exit_push",
      "@cozy_animations:container.container_animation_alpha_exit_pop",
      "@cozy_animations:container.container_animation_alpha_enter_pop",
      "@cozy_animations:container.container_animation_alpha_enter_push"
    ]
  },
  
  "inventory_screen_content": {
    "type": "panel",
    "controls": [
      {
        "creative_inventory@cozy_screen:creative_inventory.screen_content": {
          "bindings": [
            {
              "binding_type": "global",
              "binding_name": "#is_creative_mode",
              "binding_name_override": "#visible"
            }
          ]
        }
      },
      {
        "survival_inventory@cozy_screen:inventory.screen_content": {
          "bindings": [
            {
              "binding_type": "global",
              "binding_name": "(not #is_creative_mode)",
              "binding_name_override": "#visible"
            }
          ]
        }
      }
    ]
  }
}