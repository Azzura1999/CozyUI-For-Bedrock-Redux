{
  "smithing_table_screen@crafting.inventory_screen_base": {
    "$container|default": "smithing_table",
    "$screen_content": "cozy_screen:smithing_table.screen_content",
    "$screen_bg_content": "common.empty_panel",
    "close_on_player_hurt": "$cozy_container_screen_close_on_player_hurt",
    "$screen_animations": [
      "@cozy_animations:container.container_animation_alpha_exit_push",
      "@cozy_animations:container.container_animation_alpha_exit_pop",
      "@cozy_animations:container.container_animation_alpha_enter_pop",
      "@cozy_animations:container.container_animation_alpha_enter_push"
    ]
  }
}