{
  "namespace": "cozy_screen:enchanting",
  
  "screen_content": {
    "type": "panel",
    "size": ["100.0%", "100.0%"],
    "layer": 10,
    "controls": [
      {
        "screen_panel@cozy_common:container.screen_base": {
          "$size": [176.0, 166.0],
          "controls": [
            {
              "container_exit_button@cozy_common:container.container_exit_button": {}
            },
            {
              "enchanting_panel_top_half@cozy_screen:enchanting.enchanting_panel_top_half": {}
            },
            {
              "hotbar_inventory_content@cozy_common:container.hotbar_inventory_content": {}
            },
            {
              "container_utils_content@cozy_common:container.container_utils_content": {}
            }
          ]
        }
      },
      {
        "container_gamepad_helpers@common.container_gamepad_helpers": {}
      },
      {
        "selected_item_details_factory@common.selected_item_details_factory": {}
      },
      {
        "item_lock_notification_factory@common.item_lock_notification_factory": {}
      }
    ]
  },
  
  "enchanting_panel_top_half": {
    "type": "panel",
    "layer": 10,
    "size": ["100.0%", "40.0%"],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "controls": [
      {
        "left_panel": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": ["100.0%cm", "100.0%c"],
          "offset": ["23.0%y", "8.75%"],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            {
              "book_render_panel": {
                "type": "panel",
                "size": "$size",
                "$size": ["40.0px", "40.0px"],
                "anims": [
                  "@cozy_animations:container.container_animation_size_exit_push",
                  "@cozy_animations:container.container_animation_size_exit_pop",
                  "@cozy_animations:container.container_animation_size_enter_pop",
                  "@cozy_animations:container.container_animation_size_enter_push"
                ],
                "animation_reset_name": "screen_animation_reset",
                "controls": [
                  {
                    "render": {
                      "type": "custom",
                      "offset": [0.0, "5.0%"],
                      "renderer": "enchanting_book_renderer",
                      "animation_reset_name": "screen_animation_reset",
                      "anims": [
                        "@common.screen_exit_size_animation_push",
                        "@common.screen_exit_size_animation_pop",
                        "@common.screen_entrance_size_animation_push",
                        "@common.screen_entrance_size_animation_pop"
                      ],
                      "bindings": [
                        {
                          "binding_name": "#open",
                          "binding_type": "global"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "item_gird_panel": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100.0%c", "100.0%cm"],
                "controls": [
                  {
                    "item@cozy_common:container.container_item": {
                      "$size": [20.0, 20.0],
                      "$item_collection_name": "enchanting_input_items"
                    }
                  },
                  {
                    "lapis@cozy_common:container.container_item": {
                      "$size": [20.0, 20.0],
                      "$item_collection_name": "enchanting_lapis_items"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "grid_panel": {
          "type": "panel",
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "offset": ["-5.084676%", "15.06024096385%"],
          "size": ["65% - 8px", "80% + 4px"],
          "controls": [
            {
              "dust_panel@enchanting.dust_panel": {
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "layer": 10
              }
            },
            {
              "enchantments_grid": {
                "type": "stack_panel",
                "$item_collection_name": "#enchant_buttons",
                "collection_name": "$item_collection_name",
                "size": ["100%", "100%"],
                "layer": 2,
                "controls": [
                  {
                    "1@cozy_screen:enchanting.enchant_button_panel": {
                      "collection_index": 0
                    }
                  },
                  {
                    "2@cozy_screen:enchanting.enchant_button_panel": {
                      "collection_index": 1
                    }
                  },
                  {
                    "3@cozy_screen:enchanting.enchant_button_panel": {
                      "collection_index": 2
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  
  "enchant_button_panel": {
    "type": "panel",
    "size": ["100.0%", "33.333333%"],
    "layer": 7,
    "controls": [
      {
        "unselectable_button@cozy_screen:enchanting.unselectable_button": {}
      },
      {
        "selectable_button@cozy_screen:enchanting.selectable_button": {}
      },
      {
        "dark_background@dark_background": {
          "layer": 0
        }
      }
    ]
  },
  
  "selectable_button@enchanting.base_button": {
    "$visibility_binding_name": "#selectable_button_visibility",
    "$focus_override_left": "enchanting_lapis",
    "$focus_override_right": "FOCUS_OVERRIDE_STOP",
    "sound_volume": 0.0,
    "layer": 22,
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_ok",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.menu_ok",
        "mapping_type": "focused"
      },
      {
        "from_button_id": "button.controller_back",
        "to_button_id": "button.menu_ok",
        "mapping_type": "focused",
        "ignored": "(not $is_ps4)"
      }
    ],
    "controls": [
      {"default@cozy_screen:enchanting.active_background": {}},
      {"hover@cozy_screen:enchanting.active_background_with_hover_text": {}},
      {"pressed@cozy_screen:enchanting.active_background_with_hover_text": {}},
      {"rune_text@enchanting.fail_runes": {}},
      {"enchant_cost@enchanting.success_cost": {}}
    ]
  },
  
  "unselectable_button@enchanting.base_button": {
    "$visibility_binding_name": "#unselectable_button_visibility",
    "sound_volume": 0.0,
    "layer": 22,
    "button_mappings": [],
    "controls": [
      {"default@cozy_screen:enchanting.dark_background": {}},
      {"hover@cozy_screen:enchanting.dark_background_with_hover_text": {}},
      {"pressed@cozy_screen:enchanting.dark_background": {}},
      {"rune_text@enchanting.fail_runes": {}},
      {"enchant_cost@enchanting.fail_cost": {}}
    ]
  },
  
  "dark_background@enchanting.enchanting_image": {
    "texture": "cozy/sprites/enchanting/enchanting_button_locked"
  },
  
  "dark_background_with_hover_text@enchanting.background_with_hover_text": {
    "texture": "cozy/sprites/enchanting/enchanting_button_locked"
  },
  
  "active_background@enchanting.enchanting_image": {
    "texture": "cozy/sprites/enchanting/enchanting_button_default"
  },
  
  "active_background_with_hover_text@enchanting.background_with_hover_text": {
    "texture": "cozy/sprites/enchanting/enchanting_button_hover"
  }
}