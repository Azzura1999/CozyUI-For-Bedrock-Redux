    "$checked_locked_hover_control": "cozy_screen:inventory.recipe_book_hover"
  },
  
  "recipe_book_default": {
    "type": "panel",
    "controls": [
      {
        "book": {
          "type": "image",
          "texture": "cozy/sprites/inventory/book_default",
          "size": ["88.88888888888%", "88.88888888888%"]
        }
      }
    ]
  },
  
  "recipe_book_hover": {
    "type": "panel",
    "controls": [
      {
        "book": {
          "type": "image",
          "texture": "cozy/sprites/inventory/book_hover",
          "size": ["88.88888888888%", "88.88888888888%"]
        }
      }
    ]
  },
  
  "crafting_container_cell_images@cozy_screen:inventory.container_cell_images": {
    "$cell_images_binding_condition": "always"
  },
  
  "container_cell_images": {
    "type": "panel",
    "$cell_images_binding_condition|default": "visible",
    "controls": [/*
      {
        "cell_classic@cozy_screen:inventory.cell_image_classic": {}
      },
      {
        "cell_normal@cozy_screen:inventory.cell_image_normal": {}
      },
      {
        "cell_invert@cozy_screen:inventory.cell_image_invert": {}
      },
      {
        "cell_selected@cozy_screen:inventory.cell_image_selected": {}
      },
      {
        "cell_darkgrey@cozy_screen:inventory.cell_image_darkgrey": {}
      },*/
      {
        "cell_red@cozy_screen:inventory.cell_image_red": {}
      }
    ],
    "bindings": [
      {
        "binding_name": "#container_item_background",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name",
        "binding_condition": "$cell_images_binding_condition"
      }
    ]
  },
  
  "cell_image": {
    "type": "image",
    "texture": "cozy/sprites/cell/white",
    "alpha": 0.34987,
    "size": "$size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = $index)",
        "target_property_name": "#visible"
      }
    ]
  },
  
  "cell_image_classic@cozy_screen:inventory.cell_image": {
    "$index": 0
  },
  
  "cell_image_normal@cozy_screen:inventory.cell_image": {
    "$index": 1
  },
  
  "cell_image_invert@cozy_screen:inventory.cell_image": {
    "$index": 2
  },
  
  "cell_image_red@cozy_screen:inventory.cell_image": {
    "texture": "cozy/sprites/cell/red",
    "$index": 3
  },
  
  "cell_image_selected@cozy_screen:inventory.cell_image": {
    "$index": 4
  },
  
  "cell_image_darkgrey@cozy_screen:inventory.cell_image": {
    "$index": 7
  },
  
  "tab_layout_default": {
    "type": "image",
    "texture": "cozy/sprites/inventory/tab_default",
    "size": ["100.0%", "104.16666666666%"],
    "controls": [
      {
        "iocn": {
          "type": "image",
          "size": [15.0, 15.0],
          "texture": "('textures/ui/' + $tab_icon)"
        }
      }
    ]
  },
  
  "tab_layout_hover": {
    "type": "image",
    "texture": "cozy/sprites/inventory/tab_hover",
    "size": ["100.0%", "104.16666666666%"],
    "controls": [
      {
        "icon": {
          "type": "image",
          "size": [15.0, 15.0],
          "texture": "('textures/ui/' + $tab_icon)"
        }
      }
    ]
  },
  
  "tab_toggle_template@common.toggle": {
    "$unchecked_control|default": "cozy_screen:inventory.tab_layout_default",
    "$checked_control|default": "cozy_screen:inventory.tab_layout_hover",
    "$unchecked_hover_control|default": "cozy_screen:inventory.tab_layout_default",
    "$checked_hover_control|default": "cozy_screen:inventory.tab_layout_hover",
    "$unchecked_locked_control|default": "cozy_screen:inventory.tab_layout_default",
    "$unchecked_locked_hover_control|default": "cozy_screen:inventory.tab_layout_default",
    "$checked_locked_control|default": "cozy_screen:inventory.tab_layout_default",
    "$checked_locked_hover_control|default": "cozy_screen:inventory.tab_layout_default"
  },
  
  "tab_toggle_panel": {
    "type": "panel",
    "$toggle_view_binding_name|default": "this_toggle",
    "$template_toggle|default": "cozy_screen:inventory.tab_toggle_template",
    "controls": [
      {
        "$toggle_view_binding_name@$template_toggle": {}
      }
    ]
  },
  
  "tab_toggle": {
    "type": "panel",
    "$size": [27.0, 22.0],
    "size": "$size",
    "anims": [
      "@cozy_animations:container.container_animation_size_exit_push",
      "@cozy_animations:container.container_animation_size_exit_pop",
      "@cozy_animations:container.container_animation_size_enter_pop",
      "@cozy_animations:container.container_animation_size_enter_push"
    ],
    "animation_reset_name": "screen_animation_reset",
    "controls": [
      {
        "tab_toggle@cozy_screen:inventory.tab_toggle_panel": {
          "size": ["100.0%", "109.0909090909%"],
          "$radio_toggle_group": true,
          "$toggle_name": "navigation_tab",
          "$toggle_group_default_selected": "$construction_index",
          "$toggle_tab_focus_binding_type": "global",
          "$toggle_tab_focus_binding_name": "#navigation_tab_focus_precedence",
          "$toggle_on_hover_binding_type": "global",
          "$toggle_on_hover_binding_name": "#toggle_on_hover",
          "$toggle_tts_toggle_on_text": "accessibility.state.selected",
          "$toggle_tts_toggle_off_text": "accessibility.state.unselected",
          "$toggle_tts_name": "accessibility.tab.tts.title"
        }
      }
    ]
  },
  
  "scroll_grid_panel@crafting.crafting_root_panel": {
    "type": "input_panel",
    "size": [
      "100%",
      "100%c + 2px"
    ],
    "controls": [
      {
        "grid@cozy_screen:inventory.scroll_grid": {}
      }
    ]
  },
  
  "scroll_grid": {
    "type": "grid",
    "size": [
      "100%",
      "default"
    ],
    "anchor_to": "top_left",
    "anchor_from": "top_left",
    "$binding_condition|default": "visible",
    "$grid_item_precache_count|default": 0,
    "$grid_item_template|default": "cozy_screen:creative_inventory.grid_item_for_recipe_book",
    "collection_name": "$collection_name",
    "grid_rescaling_type": "horizontal",
    "grid_item_template": "$grid_item_template",
    "bindings": [
      {
        "binding_name": "#recipe_book_total_items",
        "binding_name_override": "#maximum_grid_items",
        "binding_condition": "$binding_condition",
        "binding_type": "collection",
        "binding_collection_name": "$collection_name"
      }
    ]
  },
  
  "recipe_book_scroll_panel@crafting.scroll_panel": {
    "$scrolling_content": "cozy_screen:inventory.scroll_grid_panel",
    "$collection_name": "recipe_book",
    "$show_background|default": false,
    "$scroll_box_touch_image_control": "common.empty_panel",
    "$scroll_box_mouse_image_control": "common.empty_panel"
  }
}