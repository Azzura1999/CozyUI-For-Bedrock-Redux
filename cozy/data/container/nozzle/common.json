          "scroll_box_and_track_panel": "bar_and_track",
          "button_mappings": "$button_mappings",
          "$button_mappings": [
            {
              "from_button_id": "button.menu_select",
              "to_button_id": "button.scrollbar_touch",
              "mapping_type": "pressed",
              "button_up_right_of_first_refusal": true
            }
          ],
          "bindings": [
            {
              "binding_name": "#gesture_control_enabled"
            },
            {
              "binding_name": "(not #is_using_gamepad)",
              "binding_name_override": "#focus_for_tts_enabled_binding"
            }
          ],
          "controls": [
            {
              "layout": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100.0%", "100.0%"],
                "layer": 10,
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "controls": [
                  {
                    "viewport_panel": {
                      "type": "panel",
                      "size": ["fill", "100.0%"],
                      "controls": [
                        {
                          "scrolling_view_port": {
                            "type": "panel",
                            "size": "$scrolling_view_content_size",
                            "anchor_from": "top_left",
                            "anchor_to": "top_left",
                            "layer": 10,
                            "clips_children": true,
                            "controls": [
                              {
                                "scrolling_content": {
                                  "type": "stack_panel",
                                  "size": ["100.0%", "default"],
                                  "anchor_from": "top_left",
                                  "anchor_to": "top_left",
                                  "clips_children": false,
                                  "controls": [
                                    {
                                      "scrolling_content@$scrolling_content": {}
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "padding0": {
                      "type": "panel",
                      "size": "$scrolling_padding_size"
                    }
                  },
                  {
                    "bar_and_track_panel": {
                      "type": "panel",
                      "size": ["100.0%c", "100.0%"],
                      "anchor_from": "right_middle",
                      "anchor_to": "right_middle",
                      "controls": [
                        {
                          "bar_and_track": {
                            "type": "panel",
                            "size": ["100.0%c", "100.0%"],
                            "anchor_from": "right_middle",
                            "anchor_to": "right_middle",
                            "offset": "$scrolling_track_offset",
                            "clips_children": true,
                            "controls": [
                              {
                                "track": {
                                  "type": "scroll_track",
                                  "size": ["100%sm", "100.0%"],
                                  "layer": 2,
                                  "anchor_from": "center",
                                  "anchor_to": "center",
                                  "tts_name": "accessibility.scrollbar.tts.title",
                                  "button_mappings": [
                                    {
                                      "from_button_id": "button.menu_select",
                                      "to_button_id": "button.scrollbar_skip_track",
                                      "mapping_type": "pressed"
                                    }
                                  ]
                                }
                              },
                              {
                                "box_panel": {
                                  "type": "panel",
                                  "size": ["100.0%c", "100.0%c"],
                                  "anchor_from": "top_left",
                                  "anchor_to": "top_left",
                                  "controls": [
                                    {
                                      "box": {
                                        "type": "scrollbar_box",
                                        "size": "$scroll_size",
                                        "anchor_from": "top_left",
                                        "anchor_to": "top_left",
                                        "layer": 5,
                                        "contained": true,
                                        "visible": "$scroll_box_visible",
                                        "draggable": "vertical",
                                        "button_mappings": [
                                          {
                                            "from_button_id": "button.menu_select",
                                            "to_button_id": "button.menu_select",
                                            "mapping_type": "pressed",
                                            "button_up_right_of_first_refusal": true
                                          }
                                        ],
                                        "controls": [
                                          {
                                            "touch_box@cozy_common:container.scrollbar_box": {
                                              "ignored": "(not $touch)"
                                            }
                                          },
                                          {
                                            "mouse_box@cozy_common:container.scrollbar_box": {
                                              "ignored": "$touch"
                                            }
                                          }
                                        ]
                                      }
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  
