  "recipe_toggle_panel": {
    "type": "panel",
    "$toggle_name": "layout_toggle",
    "controls": [
      {
        "creative_cozy_layout_toggle@cozy_screen:inventory.cozy_layout_toggle": {
          "$toggle_group_forced_index": "$creative_layout_index",
          "$toggle_binding_type": "global",
          "$toggle_state_binding_name": "#is_creative_layout",
          "visible": false,
          "bindings": [
            {
              "binding_type": "global",
              "binding_name": "#is_recipe_book_layout"
            },
            {
              "binding_type": "global",
              "binding_name": "#is_creative_layout"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#is_creative_layout and #is_recipe_book_layout)",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "recipe_book_cozy_layout_toggle@cozy_screen:inventory.cozy_layout_toggle": {
          "$toggle_group_forced_index": "$recipe_book_layout_index",
          "$toggle_binding_type": "global",
          "$toggle_state_binding_name": "#is_recipe_book_layout",
          "visible": false,
          "bindings": [
            {
              "binding_type": "global",
              "binding_name": "#is_survival_layout"
            },
            {
              "binding_type": "global",
              "binding_name": "#is_creative_layout"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#is_creative_layout or #is_survival_layout)",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "survival_cozy_layout_toggle@cozy_screen:inventory.cozy_layout_toggle": {
          "$toggle_group_forced_index": "$survival_layout_index",
          "$toggle_binding_type": "global",
          "$toggle_state_binding_name": "#is_survival_layout",
          "visible": false,
          "bindings": [
            {
              "binding_type": "global",
              "binding_name": "#is_recipe_book_layout",
              "binding_name_override": "#visible"
            },
            {
              "binding_type": "global",
              "binding_name": "#is_creative_layout"
            },
            {
              "binding_type": "view",
              "source_property_name": "((not #is_creative_layout) and #is_recipe_book_layout)",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },
  
