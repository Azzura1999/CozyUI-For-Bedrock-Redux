{
  "namespace": "cozy_screen:start",
  
  "screen_content": {
    "type": "panel",
    "controls": [
      {
        "title_panel_content@common_art.start_title_panel_content": {
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [
            0.0,
            10.0
          ]
        }
      },
      {
        "button_content@cozy_screen:start.button_content": {}
      }
    ]
  },
  
  "button_content": {
    "type": "stack_panel",
    "size": ["100.0%cm", "100.0%c"],
    "offset": [25.0, 15.0],
    "controls": [
      {
        "playgame@cozy_screen:start.big_button_template": {
          "$pressed_button_name": "$play_button_target",
          "$button_text": "menu.play"
        }
      },
      {
        "padding_1": {
          "type": "panel",
          "ignored": "(not $cozy_start_screen_sever_button)",
          "size": [0.0, 3.0]
        }
      },
      {
        "sever@cozy_screen:start.big_button_template": {
          "ignored":"(not $cozy_start_screen_sever_button)",
          "$pressed_button_name": "button.menu_servers",
          "$button_text": "menu.servers"
        }
      },
      {
        "padding_2": {
          "type": "panel",
          "size": [0.0, 3.0]
        }
      },
      {
        "store@cozy_screen:start.big_button_template": {
          "$pressed_button_name": "button.menu_store",
          "$button_text": "menu.store"
        }
      },
      {
        "padding_3": {
          "type": "panel",
          "size": [0.0, 3.0]
        }
      },
      {
        "skin@cozy_screen:start.big_button_template": {
          "$pressed_button_name": "button.menu_skins",
          "$button_text": "profileScreen.header"
        }
      },
      {
        "padding_4": {
          "type": "panel",
          "size": [0.0, 3.0]
        }
      },
      {
        "horizontal_panel": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100.0%c", "100.0%cm"],
          "controls": [
            {
              "😁😁😁": {
                "type": "panel",
                "size": ["100.0%c", "100.0%cm"],
                "controls": [
                  {
                    "😁😁😁": {
                      "type": "stack_panel",
                      "orientation": "horizontal",
                      "size": ["100.0%c", "100.0%cm"],
                      "offset": [-23.0, 0.0],
                      "controls": [
                        {
                          "notification@cozy_screen:start.ssmall_button_template": {
                            "$pressed_button_name": "button.menu_inbox",
                            "$icon": "notification"
                          }
                        },
                        {
                          "padding_1": {
                            "type": "panel",
                            "size": [3.0, 3.0]
                          }
                        },
                        {
                          "setting@cozy_screen:start.small_button_template": {
                            "$pressed_button_name": "button.menu_settings",
                            "$button_text": "menu.settings"
                          }
                        },
                        {
                          "padding_2": {
                            "type": "panel",
                            "size": [3.0, 3.0]
                          }
                        },
                        {
                          "exit@cozy_screen:start.small_button_template": {
                            "$pressed_button_name": "button.menu_exit",
                            "$button_text": "progressScreen.dialog.button.leave"
                          }
                        },
                        {
                          "padding_3": {
                            "type": "panel",
                            "size": [3.0, 3.0]
                          }
                        },
                        {
                          "profile@cozy_screen:start.ssmall_button_template": {
                            "$pressed_button_name": "button.menu_profile",
                            "$icon": "profile"
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  
  "big_button_template@common.button": {
    "size": ["200.0px", "20.0px"],
    "controls": [
      {
        "button_text": {
          "type": "label",
          "layer": 5,
          "text": "$button_text",
          "font_scale_factor": 1.0
        }
      },
      {
        "default": {
          "type": "image",
          "nineslice_size": 0,
          "texture": "cozy/sprites/start/big_button_default"
        }
      },
      {
        "pressed@big_button_animation_hover": {}
      },
      {
        "hover@big_button_animation_hover": {}
      }
    ]
  },
  
  "big_button_animation_hover": {
    "type": "panel",
    "controls": [
      {
        "hover_animation": {
          "type": "image",
          "ignored": "(not $cozy_button_hover_animation)",
          "texture": "cozy/sprites/start/big_button_animation_hover",
          "size": ["100.0%", "100.0%"],
          "uv_size": [800.0, 80.0],
          "nineslice_size": 0,
          "uv": "@cozy_screen:start.big_button_hover_animation",
          "disable_anim_fast_forward": true
        }
      },
      {
        "hover": {
          "type": "image",
          "ignored": "$cozy_button_hover_animation",
          "texture": "cozy/sprites/start/big_button_hover",
          "size": ["100.0%", "100.0%"],
          "nineslice_size": 0
        }
      }
    ]
  },
  
  "big_button_hover_animation": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 16,
    "frame_step": 800,
    "fps": 16,
    "reversible": true,
    "easing": "linear"
  },
  
  "small_button_template@common.button": {
    "size": ["97.5px", "20.0px"],
    "controls": [
      {
        "button_text": {
          "type": "label",
          "layer": 5,
          "text": "$button_text",
          "font_scale_factor": 1.0
        }
      },
      {
        "default": {
          "type": "image",
          "nineslice_size": 0,
          "texture": "cozy/sprites/start/small_button_default"
        }
      },
      {
        "pressed@small_button_animation_hover": {}
      },
      {
        "hover@small_button_animation_hover": {}
      }
    ]
  },
  
  "ssmall_button_template@common.button": {
    "size": ["20.0px", "20.0px"],
    "controls": [
      {
        "icon": {
          "type": "image",
          "layer": 5,
          "size": ["75.0%", "75.0%"],
          "texture": "('cozy/sprites/start/' + $icon)"
        }
      },
      {
        "default": {
          "type": "image",
          "nineslice_size": 0,
          "texture": "cozy/sprites/square_button_default"
        }
      },
      {
        "pressed": {
          "type": "image",
          "nineslice_size": 0,
          "texture": "cozy/sprites/square_button_hover"
        }
      },
      {
        "hover": {
          "type": "image",
          "nineslice_size": 0,
          "texture": "cozy/sprites/square_button_hover"
        }
      }
    ]
  },
  
  "small_button_animation_hover": {
    "type": "panel",
    "controls": [
      {
        "hover_animation": {
          "type": "image",
          "ignored": "(not $cozy_button_hover_animation)",
          "texture": "cozy/sprites/start/small_button_animation_hover",
          "size": ["100.0%", "100.0%"],
          "uv_size": [400.0, 80.0],
          "nineslice_size": 0,
          "uv": "@cozy_screen:start.small_button_hover_animation",
          "disable_anim_fast_forward": true
        }
      },
      {
        "hover": {
          "type": "image",
          "ignored": "$cozy_button_hover_animation",
          "texture": "cozy/sprites/start/small_button_hover",
          "size": ["100.0%", "100.0%"],
          "nineslice_size": 0
        }
      }
    ]
  },
  
  "small_button_hover_animation": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 16,
    "frame_step": 400,
    "fps": 16,
    "reversible": true,
    "easing": "linear"
  }
}