{
  "gui_hotbar_grid_item": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
          {
            "selected": {
              "type": "image",
              "ignored": "$cozy_selector_gradient_animation",
              "texture": "cozy/icon/selection/hotbar_selection_0",
              "size": [24.0, 24.0],
              "alpha": 1.0,
              "layer": 2,
              "bindings": [
                {
                  "binding_name": "#slot_selected",
                  "binding_name_override": "#visible",
                  "binding_type": "collection",
                  "binding_collection_name": "$hotbar_collection_name"
                }
              ]
            }
          },
          {
            "gradient_selected@hud.gradient_selected": {
              "ignored": "(not $cozy_selector_gradient_animation)"
            }
          }
        ]
      }
    ]
  },
  
  "item_name_text_root": {
    "ignored": "$cozy_hud_item_name_hide_enchantment_text"
  },
  
  "gradient_selected": {
    "type": "image",
    "texture": "cozy/icon/selection/hotbar_selection_merged",
    "size": [24.0, 24.0],
    "uv_size": [92.0, 92.0],
    "uv": "@hud.selected_animation",
    "disable_anim_fast_forward": true,
    "alpha": 1.0,
    "layer": 2,
    "bindings": [
      {
        "binding_name": "#slot_selected",
        "binding_name_override": "#visible",
        "binding_type": "collection",
        "binding_collection_name": "$hotbar_collection_name"
      }
    ]
  },
  
  "selected_animation": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 8,
    "frame_step": 92,
    "fps": 0.05,
    "reversible": true,
    "easing": "linear"
  },
  
  "hotbar_slot_selected_image": {
    "ignored": true
  },
  
  "hotbar_chooser": {
    "size": ["180.0px", "0.0px"],
    "clips_children": true
  },
  
  "empty_progress_bar": {
    "alpha": 0.0
  },
  
  "full_progress_bar": {
    "alpha": 0.0
  },
  
  "progress_bar_nub": {
    "alpha": 0.0
  },
  
  "hotbar_hud_item_icon@common.item_renderer": {
    "layer": 100,
    "$item_collection_name": "$hotbar_collection_name",
    "property_bag": {
      "force_update": true
    }
  },
  
  "cozy_hotbar_panel": {
    "type": "input_panel",
    "prevent_touch_input": true,
    "size": ["100%c", "100.0%cm"],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "bindings": [
      {
        "binding_type": "global",
        "binding_name": "#hud_visible",
        "binding_name_override": "#visible"
      }
    ],
    "controls": [
      {
        "exp_stack_panel": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["180.0px", "5.0px"],
          "offset": [0.0, -6.0],
          "clips_children": true,
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "controls": [
            {
              "exp_panel": {
                "type": "panel",
                "size": ["180.0px", "5.0px"],
                "bindings": [
                  {
                    "binding_name": "#hotbar_with_xp_bar",
                    "binding_name_override": "#visible"
                  }
                ],
                "controls": [
                  {
                    "full_progress_bar": {
                      "type": "image",
                      "texture": "cozy/icon/experience_bar_progress/experience_bar_progress_0",
                      "layer": 2,
                      "ignored": "$cozy_exp_bar_gradient_animation",
                      "clip_direction": "left",
                      "clip_pixelperfect": false,
                      "bindings": [
                        {
                          "binding_name": "#exp_progress",
                          "binding_name_override": "#clip_ratio",
                          "binding_type": "global"
                        }
                      ]
                    }
                  },
                  {
                    "full_progress_bar_gradient@hud.gradient_experience_bar_progress": {
                      "ignored": "(not $cozy_exp_bar_gradient_animation)",
                      "clip_direction": "left",
                      "clip_pixelperfect": false,
                      "bindings": [
                        {
                          "binding_name": "#exp_progress",
                          "binding_name_override": "#clip_ratio",
                          "binding_type": "global"
                        }
                      ]
                    }
                  },
                  {
                    "empty_progress_bar": {
                      "type": "image",
                      "texture": "cozy/icon/experience_bar_progress/exp_empty_bar_progress"
                    }
                  }
                ]
              }
            },
            {
              "horse_jump_renderer@hud.horse_jump_renderer": {
                "size": ["100.0%", "5.0px"],
                "layer": 7,
                "bindings": [
                  {
                    "binding_name": "#hotbar_no_xp_bar",
                    "binding_name_override": "#visible"
                  }
                ]
              }
            },
            {
              "locator_bar": {
                "type": "custom",
                "size": ["100.0%", "5.0px"],
                "renderer": "locator_bar",
                "layer": 7,
                "bindings": [
                  {
                    "binding_name": "#hotbar_with_locator_bar",
                    "binding_name_override": "#visible"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "hotbar_stack_panel": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100%c", "100.0%cm"],
          "controls": [
            {
              "hotbar_bg": {
                "type": "image",
                "size": ["100.0%c", 22.0],
                "texture": "cozy/icon/hotbar",
                "controls": [
                  {
                    "hotbar_grid@hud.hotbar_grid": {}
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  
  "gradient_experience_bar_progress": {
    "type": "image",
    "texture": "cozy/icon/experience_bar_progress/experience_bar_progress_merged",
    "size": [180.0, 5.0],
    "uv_size": [728.0, 20.0],
    "uv": "@hud.experience_bar_progress_animation",
    "disable_anim_fast_forward": true,
    "alpha": 1.0,
    "layer": 2
  },
  
  "experience_bar_progress_animation": {
    "anim_type": "flip_book",
    "initial_uv": [0, 0],
    "frame_count": 8,
    "frame_step": 728,
    "fps": 0.05,
    "reversible": true,
    "easing": "linear"
  },
  
  "locator_bar": {
    "ignored": true
  },

  "centered_gui_elements_at_bottom_middle": {
