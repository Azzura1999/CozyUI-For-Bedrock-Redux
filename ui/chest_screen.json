      "@cozy_animations:container.container_animation_alpha_enter_pop",
      "@cozy_animations:container.container_animation_alpha_enter_push"
    ],
    "variables": [
      {
        "requires": "$cozy_new_ender_chest_texture",
        "$container": "new_ender_chest"
      },
      {
        "requires": "(not $cozy_new_ender_chest_texture)",
        "$container": "ender_chest"
      }
    ]
  },
  
