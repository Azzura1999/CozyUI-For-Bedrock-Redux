{
  "namespace": "cozy_screen:chest",
  
  "small_chest_screen_panel@cozy_screen:chest.screen_content": {
    "$size": [176.0, 166.0]
  },
  
  "large_chest_screen_panel@cozy_screen:chest.screen_content": {
    "$size": [176.0, 220.0]
  },
  
  "screen_content": {
    "type": "panel",
    "size": ["100.0%", "100.0%"],
    "layer": 10,
    "controls": [
      {
        "screen_panel@cozy_common:container.screen_base": {
          "$size": "$size",
          "controls": [
            {
              "container_exit_button@cozy_common:container.container_exit_button": {}
            },
            {
              "chest_gird_panel@cozy_screen:chest.small_chest_gird_panel": {
                "ignored": "(not (($container = small_chest) or ($container = shulker_box) or ($container = new_ender_chest)))",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [0.0, "114514.1919810%cm"]
              }
            },
            {
              "ender_chest_gird_panel@cozy_screen:chest.small_chest_gird_panel": {
                "ignored": "(not ($container = ender_chest))",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [0.0, "114514.1919810%cm - 2.0px"]
              }
            },
            {
              "large_chest_gird_panel@cozy_screen:chest.large_chest_gird_panel": {
                "ignored": "(not ($container = large_chest))",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [0.0, "114514.1919810%cm"]
              }
            },
            {
              "hotbar_inventory_content@cozy_common:container.hotbar_inventory_content": {}
            },
            {
              "container_utils_content@cozy_common:container.container_utils_content": {}
            }
          ]
        }
      },
      {
        "container_gamepad_helpers@common.container_gamepad_helpers": {}
      },
      {
        "selected_item_details_factory@common.selected_item_details_factory": {}
      },
      {
        "item_lock_notification_factory@common.item_lock_notification_factory": {}
      }
    ]
  },
  
  "small_chest_gird_panel": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100.0%cm", "100.0%c"],
    "controls": [
      {"line0@cozy_common:container.container_stack_panel_line": {}},
      {
        "top@cozy_common:container.container_item_stack_template": {
          "$index": 0,
          "$item_collection_name": "container_items"
        }
      },
      {"line1@cozy_common:container.container_stack_panel_line": {}},
      {
        "middle@cozy_common:container.container_item_stack_template": {
          "$index": 9,
          "$item_collection_name": "container_items"
        }
      },
      {"line2@cozy_common:container.container_stack_panel_line": {}},
      {
        "bottom@cozy_common:container.container_item_stack_template": {
          "$index": 18,
          "$item_collection_name": "container_items"
        }
      }
    ]
  },
  
  "large_chest_gird_panel": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100.0%cm", "100.0%c"],
    "controls": [
      {
        "top1@cozy_common:container.container_item_stack_template": {
          "$index": 0,
          "$item_collection_name": "container_items"
        }
      },
      // {"line1@cozy_common:container.container_stack_panel_line": {}},
      {
        "top0@cozy_common:container.container_item_stack_template": {
          "$index": 9,
          "$item_collection_name": "container_items"
        }
      },
      {"line2@cozy_common:container.container_stack_panel_line": {}},
      {
        "middle1@cozy_common:container.container_item_stack_template": {
          "$index": 18,
          "$item_collection_name": "container_items"
        }
      },
      {"line3@cozy_common:container.container_stack_panel_line": {}},
      {
        "middle0@cozy_common:container.container_item_stack_template": {
          "$index": 27,
          "$item_collection_name": "container_items"
        }
      },
      {"line4@cozy_common:container.container_stack_panel_line": {}},
      {
        "bottom1@cozy_common:container.container_item_stack_template": {
          "$index": 36,
          "$item_collection_name": "container_items"
        }
      },
      {"line5@cozy_common:container.container_stack_panel_line": {}},
      {
        "bottom0@cozy_common:container.container_item_stack_template": {
          "$index": 45,
          "$item_collection_name": "container_items"
        }
      }
    ]
  }
}