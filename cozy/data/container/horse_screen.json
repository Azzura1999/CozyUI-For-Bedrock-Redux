{
  "namespace": "cozy_screen:horse",
  
  "screen_content": {
    "type": "panel",
    "size": ["100.0%", "100.0%"],
    "layer": 10,
    "controls": [
      {
        "screen_panel@cozy_common:container.screen_base": {
          "$size": [176.0, 166.0],
          "controls": [
            {
              "container_exit_button@cozy_common:container.container_exit_button": {}
            },
            {
              "horse_panel_top_half@cozy_screen:horse.horse_panel_top_half": {}
            },
            {
              "hotbar_inventory_content@cozy_common:container.hotbar_inventory_content": {}
            },
            {
              "container_utils_content@cozy_common:container.container_utils_content": {}
            }
          ]
        }
      },
      {
        "container_gamepad_helpers@common.container_gamepad_helpers": {}
      },
      {
        "selected_item_details_factory@common.selected_item_details_factory": {}
      },
      {
        "item_lock_notification_factory@common.item_lock_notification_factory": {}
      }
    ]
  },
  
  "horse_panel_top_half": {
    "type": "panel",
    "layer": 10,
    "size": ["92.42588%", "40.0%"],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "controls": [
      {
        "equipment_panel": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100.0%c", "100.0%cm"],
          "offset": [0.0, "7.0%x"],
          "controls": [
            {
              "equipment_gird": {
                "type": "stack_panel",
                "size": ["100.0%cm", "100.0%c"],
                "$item_collection_name": "horse_equip_items",
                "collection_name": "$item_collection_name",
                "controls": [
                  {"line0@cozy_common:container.container_stack_panel_line": {}},
                  {
                    "0@cozy_common:container.container_item": {
                      "collection_index": 0
                    }
                  },
                  {"line1@cozy_common:container.container_stack_panel_line": {}},
                  {
                    "1@cozy_common:container.container_item": {
                      "collection_index": 1
                    }
                  },
                  {"line2@cozy_common:container.container_stack_panel_line": {}},
                  {
                    "2@cozy_common:container.container_item": {
                      "collection_index": 2
                    }
                  }
                ]
              }
            },
            {
              "horse_renderer": {
                "type": "panel",
                "$size": [54.0, 54.0],
                "size": "$size",
                "anims": [
                  "@cozy_animations:container.container_animation_size_exit_push",
                  "@cozy_animations:container.container_animation_size_exit_pop",
                  "@cozy_animations:container.container_animation_size_enter_pop",
                  "@cozy_animations:container.container_animation_size_enter_push"
                ],
                "animation_reset_name": "screen_animation_reset",
                "controls": [
                  {
                    "horse_custom_panel": {
                      "type": "panel",
                      "size": ["30%", "30%"],
                      "offset": [0.0, "30%"],
                      "controls": [
                        {
                          "horse_custom": {
                            "type": "custom",
                            "animation_reset_name": "screen_animation_reset",
                            "anims": [
                              "@common.screen_exit_size_animation_push",
                              "@common.screen_exit_size_animation_pop",
                              "@common.screen_entrance_size_animation_push",
                              "@common.screen_entrance_size_animation_pop"
                            ],
                            "renderer": "live_horse_renderer",
                            "layer": 4,
                            "anchor_from": "center",
                            "anchor_to": "center",
                            "bindings": [
                              {
                                "binding_name": "#entity_id"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "inventory_panel": {
                "type": "panel",
                "size": "$size",
                "$size": [90.0, 51.0],
                "anims": [
                  "@cozy_animations:container.container_animation_size_exit_push",
                  "@cozy_animations:container.container_animation_size_exit_pop",
                  "@cozy_animations:container.container_animation_size_enter_pop",
                  "@cozy_animations:container.container_animation_size_enter_push"
                ],
                "animation_reset_name": "screen_animation_reset",
                "controls": [
                  {
                    "gird@cozy_screen:horse.horse_container_gird": {}
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  
