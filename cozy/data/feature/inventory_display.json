      {
        "slot_bindings@cozy_feature:inventory_display.slot_bindings": {}
      },
      {
        "background": {
          "type": "image",
          "texture": "cozy/icon/inventory_display/inventory_background",
          "size": ["100.0%sm", "100.0%sm"]
        }
      }
    ],
    "bindings": [
      {
        "binding_type":"view",
        "source_control_name":"slot_bindings",
        "source_property_name":"#🙊🙊🙊",
        "target_property_name": "#🐖🐖🐖"  // https://b23.tv/wVHhZtc
      },
      {
        "binding_type": "view",
        "source_property_name": "(#🐖🐖🐖 > 0)",
        "target_property_name": "#visible"
      }
    ]
  },
  
